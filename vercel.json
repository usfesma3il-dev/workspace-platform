{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@workspace_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@workspace_supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@workspace_service_role_key",
    "WHEREBY_API_KEY": "@workspace_whereby_api_key",
    "NEXT_PUBLIC_WHEREBY_API_KEY": "@workspace_whereby_api_key_public"
  }
}
